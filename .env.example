# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── MQTT ──────────────────────────────────────────────────────────────────────
# MQTT_BROKER: hostname or IP used to establish the TCP connection.
MQTT_BROKER=localhost
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CA_CERT=certs/ca.crt

# MQTT_TLS_SERVER_NAME: the CN/SAN name on the broker's TLS certificate.
# Only set this when MQTT_BROKER differs from the cert name.
# e.g. local dev connects via "localhost" but the cert is issued for "mqtt.eversource-ai.com"
# Leave empty in production when MQTT_BROKER already matches the cert.
MQTT_TLS_SERVER_NAME=mqtt.eversource-ai.com

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Nginx and Orion are deployed on the same machine, set to 127.0.0.1
# Local development without Nginx can leave this empty.
TRUSTED_PROXIES=127.0.0.1

# ── ETL Source DB (ima_thing) ─────────────────────────────────────────────────
# Only required when running etl-meta or etl-telemetry.
SRC_DB_HOST=192.168.x.x
SRC_DB_PORT=3306
SRC_DB_USER=
SRC_DB_PASSWORD=
SRC_DB_NAME=ima_thing
SRC_DB_SCHEMA=ima_thing

# ── ETL Telemetry ─────────────────────────────────────────────────────────────
# Worker tuning — set these in .env and leave them.
ETL_WORKERS=1
ETL_BATCH_SLEEP_MS=200

# Per-run parameters — recommended to pass on the command line, not stored here.
# Leaving them here as a reference only.
#
# Date range (YYYY-MM-DD or YYYY-MM-DDTHH:MM:SS).
# Defaults: FROM = 1 year ago, TO = today.
# ETL_FROM=2024-01-01
# ETL_TO=2024-12-31
#
# Filter by utility_id (comma-separated). Leave empty to process all sites.
# ETL_UTILITY_IDS=05755a6b1a1,12345x
#
# Filter by device type (comma-separated). Leave empty to process all types.
# ETL_DEVICE_TYPES=SE,CI,SF
#
# Example — migrate one site, one month, SE only:
#   ETL_UTILITY_IDS=05755a6b1a1 ETL_FROM=2024-01-01 ETL_TO=2024-01-31 ETL_DEVICE_TYPES=SE \
#     go run cmd/etl-telemetry/main.go

