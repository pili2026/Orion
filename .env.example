# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── MQTT ──────────────────────────────────────────────────────────────────────
# MQTT_BROKER: hostname or IP of the Mosquitto broker.
# Must match the CN / SAN on the broker's TLS certificate.
MQTT_BROKER=localhost
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CA_CERT=certs/ca.crt

# TRUSTED_PROXIES: comma-separated IPs/CIDRs of your reverse proxy / load balancer.
# Leave empty for local development. Must be set in production.
# Example: TRUSTED_PROXIES=10.0.0.1,10.0.0.2/24
TRUSTED_PROXIES=127.0.0.1
